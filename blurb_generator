<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rosie Hub — Blurb Tool</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #f5f4f0; --sidebar-bg: #111; --card-bg: #fff; --border: #e2e0d8;
    --text: #111; --muted: #6b6b6b; --red: #E8533A; --yellow: #F5C842;
    --green: #3DBB6E; --blue: #4A6CF7; --navy: #1e2a4a;
    --font: 'DM Sans', sans-serif; --serif: 'DM Serif Display', serif;
  }
  body { font-family: var(--font); background: var(--bg); color: var(--text); display: flex; min-height: 100vh; font-size: 14px; }

  /* SIDEBAR */
  .sidebar { width: 260px; min-height: 100vh; background: var(--sidebar-bg); color: #fff; display: flex; flex-direction: column; flex-shrink: 0; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; }
  .sb-logo { padding: 20px 24px 16px; border-bottom: 1px solid #2a2a2a; }
  .sb-we { font-size: 11px; font-style: italic; color: #aaa; display: block; }
  .sb-name { font-size: 28px; font-weight: 900; letter-spacing: -0.02em; line-height: 1; }
  .sb-nav { padding: 16px 0; flex: 1; overflow-y: auto; }
  .sb-section { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 14px 24px 6px; display: flex; justify-content: space-between; }
  .sb-section.c { color: var(--red); } .sb-section.f { color: var(--yellow); } .sb-section.u, .sb-section.co { color: var(--green); }
  .sb-section em { color: #555; font-size: 13px; font-weight: 400; font-style: normal; }
  .sb-item { display: flex; align-items: center; gap: 10px; padding: 8px 24px; font-size: 13px; color: #aaa; cursor: pointer; transition: all .15s; }
  .sb-item:hover { color: #fff; background: #1e1e1e; }
  .sb-item.on { color: #fff; }
  .sb-item .n { font-size: 11px; color: #555; min-width: 20px; }

  /* TOPBAR */
  .main { margin-left: 260px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
  .topbar { display: flex; align-items: center; justify-content: space-between; padding: 0 40px; height: 56px; background: var(--bg); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 50; }
  .tb-title { font-weight: 700; font-size: 15px; } .tb-title span { color: var(--red); }
  .tb-right { display: flex; align-items: center; gap: 12px; }
  .tb-search { display: flex; align-items: center; gap: 8px; padding: 6px 14px; border: 1px solid #ccc; border-radius: 6px; background: white; font-size: 12px; color: #666; cursor: pointer; font-family: var(--font); }
  .avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--red); color: white; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }

  /* SCREENS */
  .screen { display: none; padding: 36px 40px 80px; }
  .screen.on { display: block; }

  /* SHARED */
  .back { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; border: 1px solid var(--border); border-radius: 8px; background: white; font-size: 13px; font-weight: 500; cursor: pointer; margin-bottom: 28px; transition: all .15s; font-family: var(--font); }
  .back:hover { background: var(--bg); }
  .pg-title { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
  .rule { border: none; border-top: 1px solid var(--border); margin: 16px 0 24px; }
  .muted { color: var(--muted); }

  /* SCREEN 1 — JOBS */
  .search-row { display: flex; gap: 0; margin-bottom: 24px; }
  .search-input { flex: 1; padding: 12px 18px; border: 1px solid var(--border); border-right: none; border-radius: 8px 0 0 8px; font-size: 14px; font-family: var(--font); background: white; outline: none; }
  .search-input:focus { border-color: #999; }
  .search-btn-go { padding: 0 18px; background: var(--navy); color: white; border: none; border-radius: 0 8px 8px 0; cursor: pointer; font-size: 18px; }
  .results-label { font-size: 15px; font-weight: 600; margin-bottom: 12px; }
  .results-count { font-size: 13px; color: var(--muted); margin-bottom: 16px; }

  .job-card { background: white; border: 1px solid var(--border); border-radius: 10px; padding: 20px 24px; margin-bottom: 12px; cursor: pointer; transition: all .15s; }
  .job-card:hover { border-color: #bbb; box-shadow: 0 2px 10px rgba(0,0,0,.06); }
  .jc-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12px; }
  .jc-title { font-size: 16px; font-weight: 700; }
  .jc-company { font-size: 13px; color: var(--muted); margin-top: 2px; }
  .jc-status { font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 20px; background: #f0f0ed; color: #555; flex-shrink: 0; }
  .jc-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 24px; font-size: 12px; color: var(--muted); }
  .jc-chevron { text-align: center; color: #ccc; margin-top: 10px; font-size: 11px; letter-spacing: .1em; }

  /* SCREEN 2 — CANDIDATES */
  .cands-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
  .filter-row { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--muted); }
  .filter-sel { padding: 7px 12px; border: 1px solid var(--border); border-radius: 8px; background: white; font-family: var(--font); font-size: 13px; }

  .cand-card { background: white; border: 1px solid var(--border); border-radius: 10px; padding: 20px 24px; margin-bottom: 12px; display: flex; align-items: center; gap: 20px; }
  .cand-av { width: 60px; height: 60px; border-radius: 50%; border: 1px solid var(--border); background: #f0ede8; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #c5bfb5; }
  .cand-av svg { width: 30px; height: 30px; }
  .cand-info { flex: 1; min-width: 0; }
  .cand-name { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
  .cand-contact { display: flex; align-items: center; gap: 14px; font-size: 12px; color: var(--muted); margin-bottom: 8px; }
  .redact { display: inline-block; width: 110px; height: 11px; background: #e0ddd6; border-radius: 3px; vertical-align: middle; }
  .cand-assign { font-size: 12px; color: var(--muted); }
  .cand-assign b { color: var(--text); font-weight: 500; }
  .gen-btn { padding: 10px 20px; background: var(--navy); color: white; border: none; border-radius: 8px; font-family: var(--font); font-size: 13px; font-weight: 600; cursor: pointer; white-space: nowrap; flex-shrink: 0; transition: opacity .15s; }
  .gen-btn:hover { opacity: .85; }

  /* SCREEN 3 — GENERATOR */
  .ctx-bar { background: white; border: 1px solid var(--border); border-radius: 10px; padding: 14px 20px; margin-bottom: 24px; display: flex; align-items: center; gap: 16px; }
  .ctx-av { width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--border); background: #f0ede8; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #c5bfb5; }
  .ctx-av svg { width: 24px; height: 24px; }
  .ctx-name { font-size: 15px; font-weight: 700; }
  .ctx-sub { font-size: 12px; color: var(--muted); }
  .ctx-sep { width: 1px; height: 36px; background: var(--border); margin: 0 4px; flex-shrink: 0; }
  .ctx-job-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); }
  .ctx-job-val { font-size: 13px; font-weight: 500; }

  .tool-grid { display: grid; grid-template-columns: 380px 1fr; gap: 24px; align-items: start; }

  /* CONFIG PANEL */
  .cfg { background: white; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  .cfg-head { padding: 18px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
  .cfg-head h2 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
  .badge { font-size: 10px; font-weight: 700; letter-spacing: .08em; background: #EEF1FE; color: var(--blue); padding: 3px 8px; border-radius: 4px; text-transform: uppercase; }
  .cfg-body { padding: 20px 24px; }

  .fl { margin-bottom: 18px; }
  .fl-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); margin-bottom: 6px; }
  .fl-input { width: 100%; padding: 9px 12px; border: 1px solid var(--border); border-radius: 8px; font-family: var(--font); font-size: 13px; background: var(--bg); color: var(--text); outline: none; transition: border-color .15s; }
  .fl-input:focus { border-color: #999; }
  textarea.fl-input { min-height: 80px; resize: vertical; line-height: 1.5; }

  .fmt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
  .fmt-card { border: 1.5px solid var(--border); border-radius: 8px; padding: 10px 12px; cursor: pointer; transition: all .15s; background: var(--bg); }
  .fmt-card:hover { border-color: #aaa; }
  .fmt-card.sel { border-color: var(--text); background: var(--text); color: white; }
  .fmt-name { font-size: 12px; font-weight: 600; margin-bottom: 2px; }
  .fmt-desc { font-size: 10px; color: #999; line-height: 1.3; }
  .fmt-card.sel .fmt-desc { color: #bbb; }

  .sects { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px; }
  .sects-title { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); margin-bottom: 10px; }
  .ck { display: flex; align-items: center; gap: 9px; padding: 5px 0; cursor: pointer; user-select: none; }
  .ck input { display: none; }
  .ck-box { width: 16px; height: 16px; border-radius: 4px; border: 1.5px solid #ccc; background: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all .12s; }
  .ck input:checked + .ck-box { background: var(--text); border-color: var(--text); }
  .ck input:checked + .ck-box::after { content: ''; width: 8px; height: 5px; border-left: 1.5px solid white; border-bottom: 1.5px solid white; transform: rotate(-45deg) translateY(-1px); display: block; }
  .ck-lbl { font-size: 12px; }
  .ck-def { font-size: 9px; font-weight: 600; color: var(--muted); background: #e8e6e0; padding: 1px 5px; border-radius: 3px; margin-left: auto; text-transform: uppercase; }
  .divider { height: 1px; background: var(--border); margin: 12px 0; }

  .go-btn { width: 100%; padding: 12px; background: var(--text); color: white; border: none; border-radius: 8px; font-family: var(--font); font-size: 13px; font-weight: 600; cursor: pointer; letter-spacing: .02em; transition: opacity .15s; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 16px; }
  .go-btn:hover { opacity: .85; }
  .go-btn:disabled { opacity: .45; cursor: not-allowed; }

  /* OUTPUT */
  .out-panel { display: flex; flex-direction: column; gap: 16px; }
  .out-card { background: white; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  .out-head { padding: 14px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .out-head-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
  .out-actions { display: flex; gap: 8px; align-items: center; }
  .a-btn { padding: 5px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 11px; font-weight: 500; background: white; cursor: pointer; transition: all .12s; font-family: var(--font); }
  .a-btn:hover { background: var(--bg); }
  .a-btn.p { background: var(--text); color: white; border-color: var(--text); }
  .out-body { padding: 20px; }

  .skel { animation: shim 1.4s ease-in-out infinite; }
  @keyframes shim { 0%,100%{opacity:1} 50%{opacity:.35} }
  .sl { height: 13px; border-radius: 4px; background: #e0ddd6; margin-bottom: 8px; }
  .sl.s { width: 40%; } .sl.m { width: 68%; } .sl.f { width: 100%; }

  /* blurb content */
  .bs { margin-bottom: 16px; }
  .bs:last-child { margin-bottom: 0; }
  .bs-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-bottom: 6px; }
  .bs-text { font-size: 13px; line-height: 1.65; }
  .chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .chip { font-size: 11px; padding: 3px 10px; border-radius: 20px; background: var(--bg); border: 1px solid var(--border); }
  .meta-row { display: flex; flex-wrap: wrap; gap: 16px; }
  .mi { font-size: 12px; color: var(--muted); }
  .mi b { color: var(--text); font-weight: 600; }
  .mi a { color: var(--blue); text-decoration: none; }
  .fit-box { background: #f0f7f3; border-left: 3px solid var(--green); border-radius: 0 8px 8px 0; padding: 12px 14px; }
  .fit-box .bs-label { color: #2a9a55; }
  .pp-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--red); margin-bottom: 4px; }
  .sd-text { font-size: 14px; line-height: 1.7; font-style: italic; border-left: 3px solid var(--text); padding-left: 16px; }

  .pill { display: inline-flex; align-items: center; gap: 5px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; padding: 3px 8px; border-radius: 20px; }
  .pill.gen { background: #FEF3C7; color: #92400E; }
  .pill.done { background: #D1FAE5; color: #065F46; }
  .pill-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .pill.gen .pill-dot { animation: blink 1s ease-in-out infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }

  .empty { text-align: center; padding: 60px 20px; color: var(--muted); }
  .empty-icon { font-size: 30px; margin-bottom: 12px; opacity: .25; }
  .empty-title { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
  .empty-desc { font-size: 12px; }

  .hidden { display: none !important; }
</style>
</head>
<body>

<aside class="sidebar">
  <div class="sb-logo"><span class="sb-we">we are</span><div class="sb-name">ROSIE</div></div>
  <nav class="sb-nav">
    <div class="sb-section c">Client <em>−</em></div>
    <div class="sb-item"><span class="n">01</span> Candidate Search</div>
    <div class="sb-item"><span class="n">02</span> AI Job Description</div>
    <div class="sb-item on"><span class="n">03</span> Blurb Tool</div>
    <div class="sb-section f">Finance <em>−</em></div>
    <div class="sb-item"><span class="n">04</span> Margin Calculator</div>
    <div class="sb-section u">Utilization <em>−</em></div>
    <div class="sb-item"><span class="n">05</span> Utilization Dashboard</div>
    <div class="sb-item"><span class="n">06</span> Harvest Hours Tracking</div>
    <div class="sb-item"><span class="n">07</span> Supply & Demand Tracking</div>
    <div class="sb-section co">Community <em>−</em></div>
    <div class="sb-item"><span class="n">08</span> Rosie Insights</div>
    <div class="sb-item"><span class="n">09</span> Community Dashboard</div>
    <div class="sb-item"><span class="n">10</span> Rosie Portal Admin</div>
  </nav>
</aside>

<main class="main">
  <div class="topbar">
    <div class="tb-title">Rosie <span>Hub</span></div>
    <div class="tb-right">
      <button class="tb-search">Search ⌘K</button>
      <span style="font-size:12px;color:#888">aisha.muhamma...</span>
      <div class="avatar">AM</div>
    </div>
  </div>

  <!-- ══════ SCREEN 1: JOBS ══════ -->
  <div class="screen on" id="s-jobs">
    <div style="max-width:860px;">
      <div class="pg-title">Blurb generation</div>
      <hr class="rule">
      <div class="search-row">
        <input class="search-input" type="text" placeholder="Enter job title to search..." id="jobSearch">
        <button class="search-btn-go">🔍</button>
      </div>
      <div class="results-label">Jobs</div>
      <div class="results-count" id="jobCount"></div>
      <div id="jobsList"></div>
    </div>
  </div>

  <!-- ══════ SCREEN 2: CANDIDATES ══════ -->
  <div class="screen" id="s-cands">
    <div style="max-width:860px;">
      <button class="back" onclick="goTo('jobs')">← Back to Jobs</button>
      <div class="pg-title">Blurb generation</div>
      <hr class="rule">
      <div style="font-size:12px;color:var(--muted);">Candidates of</div>
      <div style="font-size:20px;font-weight:700;margin-bottom:20px;" id="s2-job-title"></div>
      <div class="cands-bar">
        <div style="font-size:13px;color:var(--muted);" id="s2-count"></div>
        <div class="filter-row">Filter by Status <select class="filter-sel"><option>All</option><option>LEAD</option><option>Submitted</option><option>Interview</option></select></div>
      </div>
      <div id="candsList"></div>
    </div>
  </div>

  <!-- ══════ SCREEN 3: GENERATOR ══════ -->
  <div class="screen" id="s-gen">
    <button class="back" onclick="goTo('cands')">← Back to Candidates</button>

    <div class="ctx-bar">
      <div class="ctx-av"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div>
      <div>
        <div class="ctx-name" id="ctx-name"></div>
        <div class="ctx-sub" id="ctx-sub"></div>
      </div>
      <div class="ctx-sep"></div>
      <div>
        <div class="ctx-job-label">Role</div>
        <div class="ctx-job-val" id="ctx-job"></div>
      </div>
    </div>

    <div class="tool-grid">
      <!-- CONFIG -->
      <div class="cfg">
        <div class="cfg-head"><h2>Configure</h2><span class="badge">Client</span></div>
        <div class="cfg-body">
          <div class="fl">
            <div class="fl-label">Additional Notes (Optional)</div>
            <textarea class="fl-input" id="extraNotes" placeholder="Key selling points, role-specific context..."></textarea>
          </div>

          <div class="fl" style="margin-bottom:0;">
            <div class="fl-label" style="margin-bottom:10px;">Output Format</div>
            <div class="fmt-grid">
              <div class="fmt-card sel" data-fmt="comp" onclick="setFmt(this)"><div class="fmt-name">Comprehensive</div><div class="fmt-desc">Background, experience, expertise + metadata</div></div>
              <div class="fmt-card" data-fmt="narr" onclick="setFmt(this)"><div class="fmt-name">Narrative</div><div class="fmt-desc">Flowing paragraphs, optional add-ons</div></div>
              <div class="fmt-card" data-fmt="four" onclick="setFmt(this)"><div class="fmt-name">4Ps</div><div class="fmt-desc">Pedigree · Passion · Potential · Play</div></div>
              <div class="fmt-card" data-fmt="simp" onclick="setFmt(this)"><div class="fmt-name">Simple & Direct</div><div class="fmt-desc">One punchy executive summary</div></div>
            </div>

            <div id="sects-comp" class="sects">
              <div class="sects-title">Included Sections</div>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Background</span><span class="ck-def">Fixed</span></label>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Experience</span><span class="ck-def">Fixed</span></label>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Expertise</span><span class="ck-def">Fixed</span></label>
              <div class="divider"></div>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Location</span><span class="ck-def">Fixed</span></label>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Hourly Rate</span><span class="ck-def">Fixed</span></label>
            </div>

            <div id="sects-narr" class="sects hidden">
              <div class="sects-title">Sections to Include</div>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Background</span><span class="ck-def">Default</span></label>
              <label class="ck"><input type="checkbox" id="n-fit"><span class="ck-box"></span><span class="ck-lbl">Why They're a Strong Fit</span></label>
              <div class="divider"></div>
              <label class="ck"><input type="checkbox" id="n-rate"><span class="ck-box"></span><span class="ck-lbl">Rate</span></label>
              <label class="ck"><input type="checkbox" id="n-li"><span class="ck-box"></span><span class="ck-lbl">LinkedIn</span></label>
              <label class="ck"><input type="checkbox" id="n-port"><span class="ck-box"></span><span class="ck-lbl">Portfolio</span></label>
            </div>

            <div id="sects-four" class="sects hidden">
              <div class="sects-title">Sections to Include</div>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Pedigree</span><span class="ck-def">Default</span></label>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Passion</span><span class="ck-def">Default</span></label>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Potential</span><span class="ck-def">Default</span></label>
              <label class="ck"><input type="checkbox" checked disabled><span class="ck-box"></span><span class="ck-lbl">Play</span><span class="ck-def">Default</span></label>
              <div class="divider"></div>
              <label class="ck"><input type="checkbox" id="fp-exp"><span class="ck-box"></span><span class="ck-lbl">Expertise (optional add-on)</span></label>
            </div>

            <div id="sects-simp" class="sects hidden">
              <div class="sects-title">About This Format</div>
              <p style="font-size:11px;color:#888;line-height:1.6;">A 3–4 sentence executive summary paragraph. No section headers, no metadata. Best for tracker notes and top-of-funnel introductions.</p>
            </div>
          </div>

          <button class="go-btn" onclick="doGenerate()" id="genBtn"><span>✦</span> Generate Blurb</button>
        </div>
      </div>

      <!-- OUTPUT -->
      <div class="out-panel" id="outPanel">
        <div class="out-card" id="emptyCard">
          <div class="out-body">
            <div class="empty">
