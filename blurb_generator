let selJob = null, selCand = null, curFmt = 'comp';

function goTo(s) {
  document.querySelectorAll('.screen').forEach(x => x.classList.remove('on'));
  document.getElementById('s-' + s).classList.add('on');
  window.scrollTo(0,0);
}

// JOBS
function renderJobs(q='') {
  const jobs = q ? JOBS.filter(j => (j.title+j.company).toLowerCase().includes(q.toLowerCase())) : JOBS;
  document.getElementById('jobCount').innerHTML = `<strong>${JOBS.length.toLocaleString()}</strong> results`;
  document.getElementById('jobsList').innerHTML = jobs.map(j => `
    <div class="job-card" onclick="pickJob(${j.id})">
      <div class="jc-top">
        <div><div class="jc-title">${j.title}</div><div class="jc-company">${j.company} · ${j.ind}</div></div>
        <div class="jc-status">${j.status}</div>
      </div>
      <div class="jc-meta">
        <div>📍 ${j.loc}</div><div>💼 ${j.type}</div>
        <div>Created on: ${j.created}</div><div>Target hire date: ${j.hire}</div>
      </div>
      <div class="jc-chevron">∨</div>
    </div>`).join('');
}
document.getElementById('jobSearch').addEventListener('input', e => renderJobs(e.target.value));

function pickJob(id) {
  selJob = JOBS.find(j => j.id===id);
  document.getElementById('s2-job-title').textContent = selJob.title;
  const cands = CANDS[id]||[];
  document.getElementById('s2-count').textContent = `${cands.length} results`;
  document.getElementById('candsList').innerHTML = cands.map(c => `
    <div class="cand-card">
      <div class="cand-av"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div>
      <div class="cand-info">
        <div class="cand-name">${c.name}</div>
        <div class="cand-contact">
          <span>✉ <span class="redact"></span></span>
          <span>📞 <span class="redact" style="width:85px"></span></span>
        </div>
        <div class="cand-assign"><b>Primary Assignment:</b> ${c.assign}</div>
      </div>
      <button class="gen-btn" onclick="pickCand('${c.id}')">Generate Blurb</button>
    </div>`).join('');
  goTo('cands');
}

function pickCand(id) {
  selCand = Object.values(CANDS).flat().find(c => c.id===id);
  document.getElementById('ctx-name').textContent = selCand.name;
  document.getElementById('ctx-sub').textContent = selCand.rate + ' · ' + selCand.loc;
  document.getElementById('ctx-job').textContent = selJob.title;
  // reset
  document.getElementById('emptyCard').classList.remove('hidden');
  document.querySelectorAll('.out-card:not(#emptyCard)').forEach(x => x.remove());
  curFmt = 'comp';
  document.querySelectorAll('.fmt-card').forEach(x => x.classList.remove('sel'));
  document.querySelector('[data-fmt="comp"]').classList.add('sel');
  document.querySelectorAll('[id^="sects-"]').forEach(x => x.classList.add('hidden'));
  document.getElementById('sects-comp').classList.remove('hidden');
  document.getElementById('extraNotes').value = '';
  goTo('gen');
}

function setFmt(el) {
  document.querySelectorAll('.fmt-card').forEach(x => x.classList.remove('sel'));
  el.classList.add('sel');
  curFmt = el.dataset.fmt;
  document.querySelectorAll('[id^="sects-"]').forEach(x => x.classList.add('hidden'));
  document.getElementById('sects-' + curFmt).classList.remove('hidden');
}

function doGenerate() {
  const btn = document.getElementById('genBtn');
  btn.disabled = true; btn.innerHTML = '<span style="display:inline-block;animation:blink 1s infinite">●</span> Generating...';
  document.getElementById('emptyCard').classList.add('hidden');
  document.querySelectorAll('.out-card:not(#emptyCard)').forEach(x => x.remove());

  const skel = mkSkel();
  document.getElementById('outPanel').appendChild(skel);
  setTimeout(() => {
    skel.remove();
    document.getElementById('outPanel').appendChild(mkResult());
    btn.disabled = false; btn.innerHTML = '<span>✦</span> Generate Blurb';
  }, 1800);
}

function mkSkel() {
  const d = document.createElement('div'); d.className = 'out-card';
  d.innerHTML = `<div class="out-head"><div class="out-head-title">Generating...</div><span class="pill gen"><span class="pill-dot"></span> Generating</span></div>
    <div class="out-body skel"><div class="sl s" style="margin-bottom:14px"></div><div class="sl f"></div><div class="sl f"></div><div class="sl m"></div><div class="sl f" style="margin-top:14px"></div><div class="sl f"></div><div class="sl s"></div></div>`;
  return d;
}

function mkResult() {
  const labels = {comp:'Comprehensive', narr:'Narrative', four:'4Ps Format', simp:'Simple & Direct'};
  const c = selCand;
  const d = document.createElement('div'); d.className = 'out-card';
  d.innerHTML = `
    <div class="out-head">
      <div class="out-head-title">${c.name} · ${labels[curFmt]}</div>
      <div class="out-actions">
        <span class="pill done"><span class="pill-dot"></span> Ready</span>
        <button class="a-btn" onclick="doCopy(this)">Copy</button>
        <button class="a-btn p">Use</button>
      </div>
    </div>
    <div class="out-body">${blurbHTML(c)}</div>`;
  return d;
}

function blurbHTML(c) {
  if (curFmt==='comp') return compHTML(c);
  if (curFmt==='narr') return narrHTML(c);
  if (curFmt==='four') return fourHTML(c);
  return simpHTML(c);
}

function compHTML(c) {
  return `
    <div class="bs"><div class="bs-label">Background</div><p class="bs-text">${c.notes}</p></div>
    <div class="bs"><div class="bs-label">Experience</div><p class="bs-text">${c.exp}</p></div>
    <div class="bs"><div class="bs-label">Expertise</div><div class="chips">${c.chips.map(x=>`<span class="chip">${x}</span>`).join('')}</div></div>
    <div class="divider"></div>
    <div class="meta-row">
      <div class="mi"><b>Location:</b> ${c.loc}</div>
      <div class="mi"><b>Rate:</b> ${c.rate}</div>
      ${c.li?`<div class="mi"><b>LinkedIn:</b> <a href="#">${c.li}</a></div>`:''}
      ${c.port?`<div class="mi"><b>Portfolio:</b> <a href="#">${c.port}</a></div>`:''}
    </div>`;
}

function narrHTML(c) {
  const showFit = document.getElementById('n-fit')?.checked;
  const showRate = document.getElementById('n-rate')?.checked;
  const showLi = document.getElementById('n-li')?.checked;
  const showPort = document.getElementById('n-port')?.checked;
  let h = `<div class="bs"><div class="bs-label">Background</div><p class="bs-text">${c.notes}</p></div>`;
  if (showFit) h += `<div class="bs"><div class="fit-box"><div class="bs-label">Why They're a Strong Fit</div><p class="bs-text">${c.name}'s background maps directly to this opportunity. Their experience building programs from scratch, managing complex stakeholder relationships, and delivering measurable results in comparable environments makes them an ideal fit for ${selJob?.title||'this role'}. They're available immediately and bring both the strategic vision and hands-on execution this engagement requires.</p></div></div>`;
  if (showRate||showLi||showPort) {
    h += `<div class="divider"></div><div class="meta-row">`;
    if (showRate) h += `<div class="mi"><b>Rate:</b> ${c.rate}</div>`;
    if (showLi && c.li) h += `<div class="mi"><b>LinkedIn:</b> <a href="#">${c.li}</a></div>`;
    if (showPort && c.port) h += `<div class="mi"><b>Portfolio:</b> <a href="#">${c.port}</a></div>`;
    h += `</div>`;
  }
  return h;
}

function fourHTML(c) {
  const showExp = document.getElementById('fp-exp')?.checked;
  let h = `
    <div class="bs"><div class="pp-label">Pedigree</div><p class="bs-text">${c.notes}</p></div>
    <div class="bs"><div class="pp-label">Passion</div><p class="bs-text">${c.name} is a builder at heart. Their career reflects a consistent pattern of stepping into ambiguous environments and creating structure, systems, and results where none previously existed. They are energized by complex, high-stakes work — and have a track record to prove it.</p></div>
    <div class="bs"><div class="pp-label">Potential</div><p class="bs-text">${c.name}'s standout strength is infrastructure creation and stakeholder alignment. They know how to manage up, execute independently, and build the organizational trust needed to drive lasting change. Their background positions them to add immediate value while building for the long term.</p></div>
    <div class="bs"><div class="pp-label">Play</div><p class="bs-text">${c.name} is ${c.loc.toLowerCase().includes('remote')?'fully remote-capable':c.loc+'-based'} and available immediately. Their background in cross-functional environments maps directly to the expectations of the ${selJob?.title||'role'}, and their experience owning results without heavy oversight makes them a strong fit for this engagement model.</p></div>`;
  if (showExp) h += `<div class="bs"><div class="bs-label">Expertise</div><div class="chips">${c.chips.map(x=>`<span class="chip">${x}</span>`).join('')}</div></div>`;
  return h;
}

function simpHTML(c) {
  const snippet = c.notes.split('. ').slice(0,3).join('. ')+'.';
  return `<div class="bs"><p class="sd-text">${snippet} For a role demanding both strategic vision and the operational credibility to execute at scale, ${c.name} brings both in equal measure.</p></div>`;
}

function doCopy(btn) {
  const txt = btn.closest('.out-card').querySelector('.out-body').innerText;
  navigator.clipboard.writeText(txt).then(()=>{ btn.textContent='Copied!'; setTimeout(()=>btn.textContent='Copy',1500); });
}

renderJobs();
</script>
