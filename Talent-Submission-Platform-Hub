        return `<div class="company-card animate-in" style="animation-delay:${i*0.07}s" onclick="openBench('${c.id}')">
            <div class="status-dropdown" onclick="event.stopPropagation()"><select class="status-select" onchange="changeStatus('${c.id}',this.value)"><option ${c.status==='Draft'?'selected':''}>Draft</option><option ${c.status==='In Review'?'selected':''}>In Review</option><option ${c.status==='Shared'?'selected':''}>Shared</option><option ${c.status==='Feedback Received'?'selected':''}>Feedback Received</option></select></div>
            <div class="card-top">
                <div class="company-logo" onclick="event.stopPropagation();triggerLogoUpload('${c.id}')">
                    ${c.logo?`<img src="${c.logo}" alt="${c.name}">`:`<span class="placeholder-text">${ini}</span>`}
                    <div class="logo-upload-overlay"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></div>
                </div>
                <div class="card-title-area"><h3>${c.name}</h3><div class="card-date">Updated ${ds}</div></div>
            </div>
            <div class="status-badge ${sMap[c.status]||'status-draft'}"><span class="dot"></span>${c.status}</div>
            <div class="card-counts">
                <div class="count-item"><span class="count-num">${c.candidates.length}</span><span class="count-label">Total</span></div>
                <div class="count-divider"></div>
                <div class="count-item"><span class="count-num" style="color:var(--status-shared)">${c.newCount}</span><span class="count-label">New</span></div>
                <div class="count-divider"></div>
                <div class="count-item"><span class="count-num" style="color:var(--text-light)">${c.previousCount}</span><span class="count-label">Previous</span></div>
            </div>
            <div class="card-footer"><div></div><div class="card-actions" onclick="event.stopPropagation()">
                <button class="card-action-btn" title="Duplicate" onclick="duplicateCompany('${c.id}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
                <button class="card-action-btn delete" title="Delete" onclick="deleteCompany('${c.id}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
            </div></div></div>`;
    }).join('');
}

function setStatusFilter(btn,status) {
    document.querySelectorAll('.hero-pill').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    activeStatusFilter = status;
    renderHub();
}
function changeStatus(id,status) { const c=companies.find(x=>x.id===id); if(c){c.status=status;c.lastUpdated=new Date().toISOString();renderHub();} }
function triggerLogoUpload(id) { uploadTargetCompanyId=id; document.getElementById('logoUploadInput').click(); }
function handleLogoUpload(e) {
    const f=e.target.files[0]; if(!f||!uploadTargetCompanyId)return;
    const r=new FileReader();
    r.onload=function(ev){const c=companies.find(x=>x.id===uploadTargetCompanyId);if(c){c.logo=ev.target.result;renderHub();}uploadTargetCompanyId=null;};
    r.readAsDataURL(f); e.target.value='';
}
function deleteCompany(id) { if(!confirm('Delete this bench?'))return; const i=companies.findIndex(c=>c.id===id); if(i>-1){companies.splice(i,1);renderHub();} }
function duplicateCompany(id) { const o=companies.find(c=>c.id===id);if(!o)return; const d=JSON.parse(JSON.stringify(o));d.id=id+'-copy-'+Date.now();d.name=o.name+' (Copy)';d.status='Draft';d.lastUpdated=new Date().toISOString();companies.push(d);renderHub(); }

// ═══ BENCH ═══
function openBench(id) {
    currentBenchId=id;
    benchFilters={role:'all',tier:'all',department:'all',search:''};
    document.getElementById('benchSearchInput').value='';
    document.getElementById('hub-view').style.display='none';
    document.getElementById('hero-header').style.display='none';
    document.getElementById('bench-view').style.display='block';
    document.getElementById('bench-view').classList.add('active');
    const company=id==='admin-base'?null:companies.find(c=>c.id===id);
    const cl=document.getElementById('benchCompanyLogo');
    const bn=document.getElementById('benchBrandName');
    if(company&&company.logo){cl.src=company.logo;cl.style.display='inline';bn.textContent='';}
    else if(company){cl.style.display='none';bn.textContent=company.name;}
    else{cl.style.display='none';bn.textContent='Admin Base';}
    isBenchAdminMode=true;
    document.getElementById('benchModeToggle').classList.add('admin');
    document.getElementById('benchModeLabel').textContent='Admin';
    document.getElementById('profile-detail').classList.remove('active');
    document.getElementById('talent-listing').style.display='block';
    buildBenchFilters(); renderBenchTalents(); window.scrollTo(0,0);
}
function closeBench() {
    document.getElementById('bench-view').style.display='none';
    document.getElementById('hub-view').style.display='block';
    document.getElementById('hero-header').style.display='block';
    currentBenchId=null; renderHub(); window.scrollTo(0,0);
}
function toggleBenchMode() {
    isBenchAdminMode=!isBenchAdminMode;
    document.getElementById('benchModeToggle').classList.toggle('admin',isBenchAdminMode);
    document.getElementById('benchModeLabel').textContent=isBenchAdminMode?'Admin':'Client';
    renderBenchTalents();
}
function getCurrentTalents() { if(currentBenchId==='admin-base')return adminBaseTalents; const c=companies.find(x=>x.id===currentBenchId); return c?c.candidates:[]; }
function buildBenchFilters() {
    const t=getCurrentTalents();
    const roles=[...new Set(t.map(x=>x.role))], tiers=[...new Set(t.map(x=>x.tier))], depts=[...new Set(t.map(x=>x.team))];
    document.getElementById('benchFiltersRow').innerHTML = `
        <div class="bench-filter-group"><label class="bench-filter-label">Role</label><div class="bench-filter-options"><button class="bench-filter-btn active" onclick="setBenchFilter(this,'role','all')">All Roles</button>${roles.map(r=>`<button class="bench-filter-btn" onclick="setBenchFilter(this,'role','${r}')">${r}</button>`).join('')}</div></div>
        <div class="bench-filter-group"><label class="bench-filter-label">Tier</label><div class="bench-filter-options"><button class="bench-filter-btn active" onclick="setBenchFilter(this,'tier','all')">All Tiers</button>${tiers.map(t=>`<button class="bench-filter-btn" onclick="setBenchFilter(this,'tier','${t}')">${t}</button>`).join('')}</div></div>
        <div class="bench-filter-group"><label class="bench-filter-label">Department</label><div class="bench-filter-options"><button class="bench-filter-btn active" onclick="setBenchFilter(this,'department','all')">All Departments</button>${depts.map(d=>`<button class="bench-filter-btn" onclick="setBenchFilter(this,'department','${d}')">${d}</button>`).join('')}</div></div>`;
}
function setBenchFilter(btn,type,val) { btn.closest('.bench-filter-options').querySelectorAll('.bench-filter-btn').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); benchFilters[type]=val; renderBenchTalents(); }
function filterBenchTalents() { benchFilters.search=document.getElementById('benchSearchInput').value; renderBenchTalents(); }
function renderBenchTalents() {
    const talents=getCurrentTalents();
    const f=talents.filter(t=>{
        return (benchFilters.role==='all'||t.role===benchFilters.role)&&(benchFilters.tier==='all'||t.tier===benchFilters.tier)&&(benchFilters.department==='all'||t.team===benchFilters.department)&&(!benchFilters.search||t.name.toLowerCase().includes(benchFilters.search.toLowerCase())||t.role.toLowerCase().includes(benchFilters.search.toLowerCase())||t.skills.some(s=>s.toLowerCase().includes(benchFilters.search.toLowerCase())));
    });
    document.getElementById('benchTotalCount').textContent=talents.length;
    document.getElementById('benchFilteredCount').textContent=f.length;
    const ea=(field,id)=>isBenchAdminMode?`class="editable" data-field="${field}" data-id="${id}" onclick="event.stopPropagation();startEdit(this)"`:'';
    const ew=(c)=>isBenchAdminMode?`${c}<span class="edit-indicator">Click to edit</span>`:c;
    document.getElementById('talentGrid').innerHTML=f.map((t,i)=>`
        <div class="talent-card animate-in" style="animation-delay:${i*0.06}s">
            <div class="talent-card-header"><div><div class="talent-name" ${ea('name',t.id)}>${ew(t.name)}</div><div class="talent-team" ${ea('team',t.id)}>${ew(t.team)}</div></div><div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.4rem;"><div class="tier-badge" ${ea('tier',t.id)}>${ew(t.tier)}</div>${renderAvailBadge(t)}</div></div>
            <div class="talent-divider"></div>
            <div class="talent-role" ${ea('role',t.id)}>${ew(t.role)}</div>
            <p class="talent-blurb" ${ea('blurb',t.id)}>${ew(t.blurb)}</p>
            <div class="talent-meta"><div class="meta-item"><div class="meta-label">Location</div><div class="meta-value" ${ea('location',t.id)}>${ew(t.location)}</div></div><div class="meta-item"><div class="meta-label">Experience</div><div class="meta-value" ${ea('experience',t.id)}>${ew(t.experience)}</div></div></div>
            <div class="talent-skills">${t.skills.slice(0,3).map(s=>`<span class="skill-tag">${s}</span>`).join('')}${t.skills.length>3?`<span class="skill-tag">+${t.skills.length-3} more</span>`:''}</div>
            <button class="view-profile-btn" onclick="event.stopPropagation();showProfile(${t.id})">View Full Profile</button>
        </div>`).join('');
}
function showProfile(tid) {
    const t=getCurrentTalents().find(x=>x.id===tid); if(!t)return;
    const ea=(f)=>isBenchAdminMode?`class="editable" data-field="${f}" data-id="${t.id}" onclick="event.stopPropagation();startEdit(this)"`:'';
    const ew=(c)=>isBenchAdminMode?`${c}<span class="edit-indicator">Click to edit</span>`:c;
    document.getElementById('profile-detail').innerHTML=`
        <button class="bench-back-btn" onclick="hideProfile()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>Back to Talent</button>
        <div class="profile-card"><div class="profile-header"><div class="profile-title"><div><h1 ${ea('name')}>${ew(t.name)}</h1><div class="profile-subtitle"><span ${ea('role')}>${ew(t.role)}</span> • <span ${ea('team')}>${ew(t.team)}</span></div></div><div class="profile-badges"><div class="badge" ${ea('tier')}>${ew(t.tier)}</div>${renderAvailBadgeProfile(t)}</div></div></div>
        <div class="profile-content"><div><div class="content-section"><h3 class="section-title-detail">Overview</h3><div class="section-content"><p class="info-text" ${ea('bio')}>${ew(t.bio)}</p></div></div><div class="content-section"><h3 class="section-title-detail">Location</h3><div class="section-content"><div class="info-value" ${ea('location')}>${ew(t.location)}</div></div></div><div class="content-section"><h3 class="section-title-detail">Experience</h3><div class="section-content"><div class="info-value" ${ea('experience')}>${ew(t.experience)}</div></div></div></div>
        <div><div class="content-section"><h3 class="section-title-detail">Core Skills</h3><div class="section-content"><div class="skills-list">${t.skills.map(s=>`<div class="skill-item">${s}</div>`).join('')}</div></div></div><div class="content-section"><h3 class="section-title-detail">Select Clients</h3><div class="section-content"><div class="clients-grid">${t.clients.map(c=>`<div class="client-tag">${c}</div>`).join('')}</div></div></div></div></div>
        <div class="comments-section">
            <h3 class="comments-title">Comments</h3>
            <div class="comment-input-area">
                <div class="comment-avatar">AM</div>
                <div class="comment-input-wrap">
                    <textarea class="comment-input" id="commentInput-${t.id}" placeholder="Add a comment..." rows="2"></textarea>
                    <button class="comment-submit" onclick="addComment(${t.id})">Post Comment</button>
                </div>
            </div>
            <div class="comments-list" id="commentsList-${t.id}">
                ${renderComments(t)}
            </div>
        </div>
        </div>`;
    document.getElementById('talent-listing').style.display='none';
    document.getElementById('profile-detail').classList.add('active');
    window.scrollTo(0,0);
}
function hideProfile() { document.getElementById('profile-detail').classList.remove('active'); document.getElementById('talent-listing').style.display='block'; }

// ═══ INLINE EDIT ═══
function startEdit(el) {
    if(el.classList.contains('editing'))return;
    el.classList.add('editing');
    const tid=parseInt(el.dataset.id),field=el.dataset.field,talents=getCurrentTalents(),t=talents.find(x=>x.id===tid),cv=t[field],long=field==='blurb'||field==='bio';
    const inp=document.createElement(long?'textarea':'input');
    inp.className=long?'inline-edit-textarea':'inline-edit-input';
    if(!long)inp.type='text'; inp.value=cv;
    const ctrl=document.createElement('div'); ctrl.className='edit-controls';
    const sb=document.createElement('button');sb.className='edit-save';sb.textContent='Save';
    sb.onclick=e=>{e.stopPropagation();t[field]=inp.value;el.classList.remove('editing');renderBenchTalents();};
    const cb=document.createElement('button');cb.className='edit-cancel';cb.textContent='Cancel';
    cb.onclick=e=>{e.stopPropagation();el.classList.remove('editing');el.innerHTML=isBenchAdminMode?cv+'<span class="edit-indicator">Click to edit</span>':cv;};
    ctrl.appendChild(sb);ctrl.appendChild(cb);
    el.innerHTML='';el.appendChild(inp);el.appendChild(ctrl);inp.focus();if(!long)inp.select();
}

// ═══ AVAILABILITY ═══
function renderAvailBadge(t) {
    const a = t.availability || 'Available';
    const cls = a === 'Available' ? 'avail-available' : a === 'On Assignment' ? 'avail-on-assignment' : 'avail-limited';
    if (isBenchAdminMode) {
        return `<select class="avail-select" onclick="event.stopPropagation()" onchange="event.stopPropagation();changeAvailability(${t.id},this.value)">
            <option ${a==='Available'?'selected':''}>Available</option>
            <option ${a==='On Assignment'?'selected':''}>On Assignment</option>
            <option ${a==='Limited'?'selected':''}>Limited</option>
        </select>`;
    }
    return `<div class="avail-badge ${cls}"><span class="avail-dot"></span>${a}</div>`;
}
function renderAvailBadgeProfile(t) {
    const a = t.availability || 'Available';
    const cls = a === 'Available' ? 'avail-available' : a === 'On Assignment' ? 'avail-on-assignment' : 'avail-limited';
    if (isBenchAdminMode) {
        return `<select class="avail-select" onchange="changeAvailability(${t.id},this.value);showProfile(${t.id})">
            <option ${a==='Available'?'selected':''}>Available</option>
            <option ${a==='On Assignment'?'selected':''}>On Assignment</option>
            <option ${a==='Limited'?'selected':''}>Limited</option>
        </select>`;
    }
    return `<div class="avail-badge ${cls}" style="font-size:0.75rem;padding:0.35rem 0.85rem;"><span class="avail-dot"></span>${a}</div>`;
}
function changeAvailability(tid, val) {
    const t = getCurrentTalents().find(x => x.id === tid);
    if (t) { t.availability = val; renderBenchTalents(); }
}

// ═══ COMMENTS ═══
function renderComments(t) {
    if (!t.comments || t.comments.length === 0) {
        return '<div style="text-align:center;padding:1.5rem;color:var(--text-light);font-size:0.8rem;">No comments yet</div>';
    }
    return t.comments.map(c => `
        <div class="comment-item">
            <div class="comment-avatar">${c.author.split(' ').map(w=>w[0]).join('').slice(0,2)}</div>
            <div class="comment-body">
                <span class="comment-author">${c.author}<span class="comment-time">${c.time}</span></span>
                <div class="comment-text">${c.text}</div>
            </div>
        </div>`).join('');
}
function addComment(tid) {
    const input = document.getElementById('commentInput-' + tid);
    const text = input.value.trim();
    if (!text) return;
    const t = getCurrentTalents().find(x => x.id === tid);
    if (!t) return;
    if (!t.comments) t.comments = [];
    const now = new Date();
    const timeStr = now.toLocaleDateString('en-US', {month:'short',day:'numeric'}) + ' at ' + now.toLocaleTimeString('en-US', {hour:'numeric',minute:'2-digit'});
    t.comments.push({ author: 'Aisha M.', text: text, time: timeStr });
    input.value = '';
    showProfile(tid);
}

// ═══ INIT ═══
document.addEventListener('DOMContentLoaded', renderHub);
</script>
</body>
</html>
